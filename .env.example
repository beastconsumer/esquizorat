# Discord Bot Token (obtenha em https://discord.com/developers/applications)
# Configure esta variável de ambiente no sistema ANTES de executar Program.py
DISCORD_TOKEN=seu_token_discord_aqui

# Exemplo (NÃO USE ESTE TOKEN):
# DISCORD_TOKEN=seu_token_aqui_exemplo

# Para Windows (Command Prompt):
# set DISCORD_TOKEN=seu_token_aqui

# Para Windows (PowerShell):
# $env:DISCORD_TOKEN = "seu_token_aqui"

# Para Linux/Mac:
# export DISCORD_TOKEN=seu_token_aqui
